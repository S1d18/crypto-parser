# Bybit API (демо-ключи создаются на bybit.com в режиме Demo Trading)
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_DEMO=true

# Telegram Bot (https://t.me/BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Торговые параметры
SYMBOL=BTC/USDT:USDT
MAX_POSITION_USDT=1000
CHECK_INTERVAL=60
CANDLES_LIMIT=100

# 4h Long стратегия
ST_PERIOD_4H=10
ST_MULTIPLIER_4H=3
SL_PERCENT_4H=3
POSITION_SIZE_4H=10

# Short стратегия (15m по умолчанию, Bybit не поддерживает 10m)
SHORT_TIMEFRAME=15m
ST_PERIOD_SHORT=10
ST_MULTIPLIER_SHORT=3
SL_PERCENT_SHORT=1
POSITION_SIZE_SHORT=5

LOG_FILE=bot.log
